
# Maintainer: Ian Bradley <crabapp@hikki.tech>
pkgname=perl-dofiles-p5
_perl_namespace=Dotfiles
_perl_module=p5
pkgver=0.01.1
pkgrel=1
pkgdesc="A collection of tools in the same vein as configuration files,
convenience/provisioning override files, et all."
arch=(x86_64 x86_64_v3 aarch64)
license=('Artistic-1.0-Perl' 'GPL-1.0-or-later')
depends=('perl')
makedepends=('perl-syntax-keyword-try' 'perl-cpanel-json-xs' 'perl-module-build' 'perl-dbi' 'cpanminus' 'perl-inline-c' 'perl-path-tiny' 'perl-net-ssleay')
optdepends=('perl-cpanel-json-xs: Using Cpanel-JSON-XS')
options=('!emptydirs')
url="https://github.com/marlencrabapple/App-bs"
source=("https://cpan.metacpan.org/authors/id/C/CR/CRABAPP/${_perl_namespace}-${_perl_module}-${pkgver}.tar.gz")
b2sums=(dffsdf)
sha512sum=('cd3937afa78831f80a2ad5abab6c51b9e82fca4c31e5856ea208d598db5dc867')
validpgpkeys=(4D8733704B740FC4B330EF5E8FFAD8B7BA73987)

prepare() {
  cd "${_perl_namespace}-${_perl_module}-${pkgver}"
  unset PERL5LIB PERL_MM_OPT PERL_MB_OPT PERL_LOCAL_LIB_ROOT

  cpanm -Llocal --save-dists . --verbose \
    vendor/{Plack,Frame,Dotfiles-p5}*.tar.gz

  cpanm -Llocal --save-dists . --installdeps --verbose .

  perl Build.PL
}

build() {
  ./Build build
}

check() {
  cd "${_perl_namespace}-${_perl_module}-${pkgver}"
  unset PERL5LIB PERL_MM_OPT PERL_MB_OPT PERL_LOCAL_LIB_ROOT
  export PERL_MM_USE_DEFAULT=1
  ./Build testall
}

package() {
  cd "${_perl_namespace}-${_perl_module}-${pkgver}"
  unset PERL5LIB PERL_MM_OPT PERL_MB_OPT PERL_LOCAL_LIB_ROOT

  ./Build install
  find "${pkgdir}" -name '.packlist' -delete
}
