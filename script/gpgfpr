#    | tail -n1 \
#    | perl -Mv5.40 -MIPC::Nosh::IO \
#      -e 'my @fpr; push @fpr, map { chomp $_; join "", $_ =~ s/(?:Key fingerprint = |\s)//gr } (<>); say join " ", @fpr; dmsg(\@fpr)'; done
