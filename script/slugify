package slugify;

class slugify : does(Dotfiles::p5::Base);

use v5.40;

use Const::Fast;
use IPC::Nosh::Common;
use Getopt::Long qw(GetOptionsFromArray :config no_ignore_case auto_abbrev);

our %cliopt = ();

field $replace : param;
field $concat  : param;
field $cliopt;

sub flag_optval ( $optspec, $val //= "" ) {
    dmsg $optspec;
    $$cliopt{ $optspec->key }->$* = $concat_defualt;
}

sub from_cli ( $argv //= \@ARGV ) {
    GetOptionsFromArray(
        \$argv,
        \%cliopt,
        'concat|join'  => \&flag_optval,
        'replace-with' => \&flag_optval,
    );
}

package slugify::cli;

my $slugify = slugify::from_cli( \@ARGV );
$slugify->

