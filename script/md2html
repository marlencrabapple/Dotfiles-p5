#!/usr/bin/env perl
use Object::Pad ':experimental(:all)';

package md2html;
use lib 'lib';

class md2html : does(Dotfiles::p5::md2html) : does(Dotfiles::p5::Base);

use utf8;
use v5.40;

use Time::HiRes 'gettimeofday';
use Getopt::Long qw(GetOptionsFromArray :config no_ignore_case bundling);

field $queue : param : reader = [];
field $argv : param = \@ARGV;
field $cliopts : param(dest) = {
    charset => 'UTF-8',
    css     => 'body {}'

    # filename => 'md2html_' . join ' ',
    # gettimeofday
};

field $env = {%$cliopts};

ADJUSTPARAMS($params) {

    GetOptionsFromArray(
        $argv, $cliopts,
        'css|stylesheet|style=s',
        'out|o=s',
        '<>' => sub ($in) {
            Dotfiles::p5::Base::dmsg(
                {
                    params => $params,
                    self   => $self
                }
            );
            push $self->queue->@*, $in;
        }
    );

    push $self->queue->@*, *STDIN;

    Dotfiles::p5::Base::dmsg(
        { md2html_symbols => \%md2html::, self => $self } );
}

method $run (%opts) {
    my $outh = $$cliopts{out} // *STDOUT;
    my @err;

    foreach my $in ( $self->queue->@* ) {
        if ( my $html = __PACKAGE__->md2html( $in, %opts ) ) {
            say $outh $html;
        }
        else {
            push @err, $?;
        }
    }
}

method run : common ($argv = \@ARGV, %opts) {
    my $self = $class->new( dest => $opts{cliopts} //= {} );
    Dotfiles::p5::Base::dmsg(
        argv => $argv,
        opts => \%opts,
        ( 'Dotfiles::p5_symboles' => %Dotfiles::p5:: )
    );
    $self->$run(%opts);
}

package main;

use v5.40;

md2html->run()

